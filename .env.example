JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES=8h
NODE_ENV=production
APP_URL=https://your-domain.example.com

DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_system

# App runtime database account
DB_USER=crm_app
DB_PASS=CrmApp@2026!

# Database admin account used only by `npm run init-db`
DB_ROOT_USER=root
DB_ROOT_PASS=

SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_JSON=

PORT=3000
SYNC_INTERVAL_MINUTES=60
SYNC_COOLDOWN_MS=15000
